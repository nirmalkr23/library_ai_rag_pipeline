<div class="min-h-screen bg-slate-950 text-slate-100">
  <%= render "shared/navbar" %>

  <main class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-white">Manage books</h1>
        <p class="text-slate-400 mt-2"><%= pluralize(@books.size, "book") %> in the library.</p>
      </div>
      <%= link_to new_admin_book_path,
            class: "rounded-lg bg-indigo-500 px-4 py-2.5 font-semibold text-white shadow-lg shadow-indigo-500/20 hover:bg-indigo-400 transition" do %>
        + Upload book
      <% end %>
    </div>

    <% if @books.empty? %>
      <div class="rounded-2xl border border-dashed border-white/15 bg-white/5 p-16 text-center">
        <div class="text-4xl mb-3">📚</div>
        <p class="text-slate-300 font-medium">No books yet</p>
        <p class="text-slate-500 text-sm mt-1">Upload your first PDF to get started.</p>
        <%= link_to "Upload a book", new_admin_book_path,
              class: "inline-block mt-5 rounded-lg bg-indigo-500 px-4 py-2.5 font-semibold text-white hover:bg-indigo-400 transition" %>
      </div>
    <% else %>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% @books.each do |book| %>
          <div class="group rounded-2xl border border-white/10 bg-white/5 p-5 hover:bg-white/[0.07] transition">
            <div class="flex items-start justify-between gap-3">
              <div class="h-12 w-12 shrink-0 rounded-lg bg-gradient-to-br from-indigo-500/20 to-fuchsia-500/20 ring-1 ring-white/10 flex items-center justify-center text-red-300 font-bold text-xs">PDF</div>
              <%= render "shared/book_status", status: book.status %>
            </div>
            <h3 class="mt-4 font-semibold text-white truncate"><%= book.title %></h3>
            <p class="text-sm text-slate-400 truncate"><%= book.author.presence || "Unknown author" %></p>
            <div class="mt-4 flex items-center justify-between text-sm">
              <span class="text-slate-500"><%= time_ago_in_words(book.created_at) %> ago</span>
              <%= button_to "Delete", admin_book_path(book), method: :delete,
                    form: { data: { turbo_confirm: "Delete “#{book.title}”?" } },
                    class: "text-slate-400 hover:text-red-300 transition cursor-pointer" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </main>
</div>
