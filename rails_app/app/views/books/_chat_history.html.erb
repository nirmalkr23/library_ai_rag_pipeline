<div id="<%= dom_id(chat_history) %>" class="space-y-3">
  <%# Question (user) %>
  <div class="flex justify-end">
    <div class="max-w-[85%] rounded-2xl rounded-br-sm bg-indigo-500 px-3.5 py-2.5 text-sm text-white">
      <%= chat_history.question %>
    </div>
  </div>
  <%# Answer (assistant) %>
  <div class="flex justify-start">
    <div class="max-w-[90%] rounded-2xl rounded-bl-sm bg-slate-800/80 ring-1 ring-white/10 px-3.5 py-2.5 text-sm text-slate-200 leading-relaxed">
      <%= simple_format(chat_history.answer) %>
    </div>
  </div>
</div>
