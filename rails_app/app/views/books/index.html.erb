<div class="min-h-screen bg-slate-950 text-slate-100">
  <%= render "shared/navbar" %>

  <main class="max-w-6xl mx-auto px-6 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white">Library</h1>
      <p class="text-slate-400 mt-2"><%= pluralize(@books.size, "book") %> ready to read &amp; ask.</p>
    </div>

    <% if @books.empty? %>
      <div class="rounded-2xl border border-dashed border-white/15 bg-white/5 p-16 text-center">
        <div class="text-4xl mb-3">📚</div>
        <p class="text-slate-300 font-medium">No books yet</p>
        <p class="text-slate-500 text-sm mt-1">
          <%= current_user.admin? ? "Upload a PDF to get started." : "Check back soon — an admin is adding books." %>
        </p>
        <% if current_user.admin? %>
          <%= link_to "Upload a book", new_admin_book_path,
                class: "inline-block mt-5 rounded-lg bg-indigo-500 px-4 py-2.5 font-semibold text-white hover:bg-indigo-400 transition" %>
        <% end %>
      </div>
    <% else %>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        <% @books.each do |book| %>
          <%= link_to book_path(book),
                class: "group rounded-2xl border border-white/10 bg-white/5 p-6 hover:bg-white/[0.07] hover:border-indigo-500/40 transition flex flex-col" do %>
            <div class="h-32 rounded-xl bg-gradient-to-br from-indigo-500/20 to-fuchsia-500/20 ring-1 ring-white/10 flex items-center justify-center text-5xl">📖</div>
            <h3 class="mt-4 font-semibold text-white truncate group-hover:text-indigo-200"><%= book.title %></h3>
            <p class="text-sm text-slate-400 truncate"><%= book.author.presence || "Unknown author" %></p>
            <div class="mt-3 flex items-center gap-2 text-xs text-slate-500">
              <span><%= pluralize(book.book_chunks.size, "chunk") %></span>
              <span>·</span>
              <span class="text-indigo-300 group-hover:text-indigo-200">Read &amp; ask →</span>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </main>
</div>
