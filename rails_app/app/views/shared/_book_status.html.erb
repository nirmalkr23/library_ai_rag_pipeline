<%#
  Colored status pill. Local: status (string).
%>
<% styles = {
     "pending"    => "bg-amber-500/15 text-amber-300 ring-amber-500/30",
     "processing" => "bg-sky-500/15 text-sky-300 ring-sky-500/30",
     "ready"      => "bg-emerald-500/15 text-emerald-300 ring-emerald-500/30",
     "failed"     => "bg-red-500/15 text-red-300 ring-red-500/30"
   } %>
<span class="rounded-full px-2.5 py-1 text-xs font-medium ring-1 <%= styles[status] || styles["pending"] %>">
  <%= status.titleize %>
</span>
