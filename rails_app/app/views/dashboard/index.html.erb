<div class="min-h-screen bg-slate-950 text-slate-100">
  <%= render "shared/navbar" %>

  <main class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-white">
      Welcome, <%= current_user.name.presence || "reader" %> 👋
    </h1>
    <p class="text-slate-400 mt-2">Browse the library, open a book, and ask the AI about it.</p>

    <div class="mt-8">
      <%= link_to "Go to Library", books_path,
            class: "rounded-lg bg-indigo-500 px-4 py-2.5 font-semibold text-white shadow-lg shadow-indigo-500/20 hover:bg-indigo-400 transition" %>
    </div>

    <% if current_user.admin? %>
      <div class="mt-8 rounded-2xl border border-white/10 bg-white/5 p-6 flex items-center justify-between">
        <div>
          <h2 class="text-lg font-semibold text-white">Add a book to the library</h2>
          <p class="text-slate-400 text-sm mt-1">Upload a PDF — it gets processed for AI Q&A.</p>
        </div>
        <%= link_to "Upload a book", new_admin_book_path,
              class: "rounded-lg bg-indigo-500 px-4 py-2.5 font-semibold text-white shadow-lg shadow-indigo-500/20 hover:bg-indigo-400 transition" %>
      </div>
    <% end %>
  </main>
</div>
