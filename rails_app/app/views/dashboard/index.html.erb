<div class="min-h-screen bg-slate-50">
  <header class="bg-white border-b border-slate-200">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="h-9 w-9 rounded-lg bg-indigo-600 flex items-center justify-center text-lg">📚</div>
        <span class="font-semibold text-slate-800">Library AI</span>
      </div>
      <div class="flex items-center gap-4 text-sm">
        <span class="text-slate-600">
          <%= current_user.name.presence || current_user.email %>
          <span class="ml-1 rounded-full bg-indigo-100 text-indigo-700 px-2 py-0.5 text-xs font-medium">
            <%= current_user.role %>
          </span>
        </span>
        <%= button_to "Sign out", destroy_user_session_path, method: :delete,
              class: "rounded-lg border border-slate-300 px-3 py-1.5 text-slate-700 hover:bg-slate-100 transition cursor-pointer" %>
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-slate-800">
      Welcome, <%= current_user.name.presence || "reader" %> 👋
    </h1>
    <p class="text-slate-500 mt-2">Your library dashboard. Books and AI chat land here next.</p>
  </main>
</div>
