#!/usr/bin/env sh
# Stop the Docker services (Postgres + Redis). Stop the Rails app with Ctrl+C
# in its own terminal first — this only handles the containers.

COMPOSE_FILE="$(CDPATH= cd "$(dirname "$0")/.." && pwd)/../docker-compose.yml"

if command -v docker >/dev/null 2>&1 && [ -f "$COMPOSE_FILE" ]; then
  echo "Stopping Docker services (postgres, redis)..."
  docker compose -f "$COMPOSE_FILE" stop
else
  echo "Docker or compose file not found."
fi
